{
  "name": "@signaltree/core",
  "version": "11.5.0",
  "description": "Reactive JSON for Angular. State as shape. Signals at every path.",
  "license": "BUSL-1.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./security": {
      "types": "./src/security.d.ts",
      "import": "./dist/security.js",
      "default": "./dist/security.js"
    },
    "./lazy": {
      "types": "./src/lazy.d.ts",
      "import": "./dist/lazy.js",
      "default": "./dist/lazy.js"
    },
    "./edit-session": {
      "types": "./src/edit-session.d.ts",
      "import": "./dist/edit-session.js",
      "default": "./dist/edit-session.js"
    },
    "./storage": {
      "types": "./src/storage.d.ts",
      "import": "./dist/storage.js",
      "default": "./dist/storage.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0 || ^21.0.0 || ^22.0.0",
    "rxjs": "^7.0.0",
    "tslib": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "src/**/*.d.ts",
    "skills/**/*",
    "README.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JBorgia/signaltree.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/JBorgia/signaltree/issues"
  },
  "homepage": "https://github.com/JBorgia/signaltree/tree/main/packages/core#readme"
}
