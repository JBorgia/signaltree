{
  "name": "@signaltree/core",
  "version": "9.5.1",
  "description": "Reactive JSON for Angular. JSON branches, reactive leaves. No actions. No reducers. No selectors.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./security": {
      "types": "./src/security.d.ts",
      "import": "./dist/security.js",
      "default": "./dist/security.js"
    },
    "./edit-session": {
      "types": "./src/edit-session.d.ts",
      "import": "./dist/edit-session.js",
      "default": "./dist/edit-session.js"
    },
    "./storage": {
      "types": "./src/storage.d.ts",
      "import": "./dist/storage.js",
      "default": "./dist/storage.js"
    },
    "./rxjs-interop": {
      "types": "./src/rxjs-interop.d.ts",
      "import": "./dist/rxjs-interop.js",
      "default": "./dist/rxjs-interop.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0 || ^21.0.0",
    "@angular/compiler": "^20.0.0 || ^21.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0 || ^21.0.0",
    "zone.js": "^0.15.0",
    "tslib": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/compiler": {
      "optional": true
    },
    "@angular/platform-browser-dynamic": {
      "optional": true
    },
    "zone.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "src/**/*.d.ts",
    "skills/**/*",
    "README.md"
  ]
}
